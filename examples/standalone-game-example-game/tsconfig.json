{
  "compilerOptions": {
    "outDir": "./build",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "strict": true,
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "dom", "dom.iterable"],
    "allowJs": true
  },
  "include": [
    "src/**/*",
    "build.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
