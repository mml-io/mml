<m-light y="50" x="0" z="0" intensity="10000" type="point"></m-light>
<m-cube id="floor" kinematic="true" width="60" depth="60" y="0" opacity="1"></m-cube>

<!-- Clickable demo cube -->
<m-cube id="cube1"
        x="0" y="1" z="-5"
        width="1.5" height="1.5" depth="1.5"
        color="#44aaee"
        onclick="(function(){
          const c = document.getElementById('cube1');
          const current = c.getAttribute('color');
          const next = current === '#44aaee' ? '#e76f51' : '#44aaee';
          c.setAttribute('color', next);
        })()"
></m-cube>

<!-- Mouse behavior controller element -->
<m-mouse-behavior id="mouse" mode="unlocked"></m-mouse-behavior>

<m-overlay anchor="top-left" offset-x="10" offset-y="10">
  <svg width="360" height="210" style="background: rgba(0,0,0,0.75); border-radius: 8px; padding: 8px;">
    <text x="8" y="18" fill="white" font-family="Arial" font-size="14">Mouse Behavior Demo</text>
    <text x="8" y="38" fill="white" font-family="Arial" font-size="12">Current:</text>
    <text id="mode-label" x="70" y="38" fill="#ffd166" font-family="Arial" font-size="12">unlocked</text>

    <rect x="8" y="52" width="90" height="26" rx="4" ry="4" fill="#1d3557" stroke="#a8dadc" stroke-width="1" style="cursor: pointer;"
      onclick="document.getElementById('mouse').setAttribute('mode','unlocked'); document.getElementById('mode-label').textContent='unlocked'">
      <title>Unlocked</title>
    </rect>
    <text x="53" y="69" text-anchor="middle" fill="#f1faee" font-size="12" style="pointer-events: none;">Unlocked</text>

    <rect x="108" y="52" width="90" height="26" rx="4" ry="4" fill="#1d3557" stroke="#a8dadc" stroke-width="1" style="cursor: pointer;"
      onclick="document.getElementById('mouse').setAttribute('mode','locked'); document.getElementById('mode-label').textContent='locked'">
      <title>Locked</title>
    </rect>
    <text x="153" y="69" text-anchor="middle" fill="#f1faee" font-size="12" style="pointer-events: none;">Locked</text>

    <text x="8" y="102" fill="#adb5bd" font-family="Arial" font-size="11">Tip: For locked mode, click the canvas to enter pointer lock.</text>

    <!-- Color selectors for cube1 -->
    <text x="8" y="125" fill="white" font-family="Arial" font-size="12">Cube Color:</text>
    <rect x="90" y="112" width="26" height="20" rx="3" ry="3" fill="#44aaee" stroke="#ffffff" stroke-width="1" style="cursor: pointer;"
      onclick="document.getElementById('cube1').setAttribute('color','#44aaee')">
      <title>Blue</title>
    </rect>
    <rect x="120" y="112" width="26" height="20" rx="3" ry="3" fill="#e76f51" stroke="#ffffff" stroke-width="1" style="cursor: pointer;"
      onclick="document.getElementById('cube1').setAttribute('color','#e76f51')">
      <title>Red</title>
    </rect>
    <rect x="150" y="112" width="26" height="20" rx="3" ry="3" fill="#2a9d8f" stroke="#ffffff" stroke-width="1" style="cursor: pointer;"
      onclick="document.getElementById('cube1').setAttribute('color','#2a9d8f')">
      <title>Teal</title>
    </rect>
    <rect x="180" y="112" width="26" height="20" rx="3" ry="3" fill="#f4a261" stroke="#ffffff" stroke-width="1" style="cursor: pointer;"
      onclick="document.getElementById('cube1').setAttribute('color','#f4a261')">
      <title>Orange</title>
    </rect>

    <!-- Spawn character button -->
    <rect x="8" y="150" width="190" height="28" rx="4" ry="4" fill="#2d6a4f" stroke="#95d5b2" stroke-width="1" style="cursor: pointer;"
      onclick="(window && window.spawnLocalCharacter) && window.spawnLocalCharacter()">
      <title>Spawn a controllable character</title>
    </rect>
    <text x="103" y="168" text-anchor="middle" fill="#f1faee" font-size="12" style="pointer-events: none;">Spawn Character</text>
  </svg>
</m-overlay>

 