<m-group id="scene-group">
  <m-plane x="0" y="0" z="0" width="400" height="400" rx="-90" color="#808080"></m-plane>
  <m-light type="point" y="20" intensity="750" cast-shadows="true"></m-light>
  
  <!-- Camera toggle cubes -->
  <m-cube id="blue-cube" x="-3" y="0.75" z="0" width="1.5" height="1.5" depth="1.5" color="rgb(0, 0, 25)"></m-cube>
  <m-cube id="red-cube" x="3" y="0.75" z="0" width="1.5" height="1.5" depth="1.5" color="rgb(25, 0, 0)"></m-cube>
  
  <!-- Cameras -->
  <m-camera id="top-down-camera" x="0" y="25" z="0" rx="-90" priority="2" visible-to="-1" fov="60">
    <m-attr-anim start="0" end="360" duration="10000" loop="true" attr="rz"></m-attr-anim>
  </m-camera>
  <m-group ry="45" x="15" y="15" z="15"><m-camera id="angle-camera" visible-to="-1" priority="1" fov="70" rx="-45"></m-camera></m-group>
</m-group>


<m-group id="stairs" z="-10" ry="180" y="0.1"></m-group>

<m-cube z="25" y="1.5" width="3" height="3" depth="3" id="my-cube"></m-cube>

<m-cube x="15" y="0.5" z="5" width="3" height="0.25" depth="3" color="blue">
  <m-attr-anim
    attr="z"
    start="-5"
    end="10000"
    duration="5000"
    loop="true"
    ping-pong="true"
    ping-pong-delay="3000"
    easing="easeInOutQuart"
  ></m-attr-anim>
</m-cube>

<m-cube x="10" y="0.5" z="5" width="3" height="0.25" depth="3" color="blue">
  <m-attr-anim
    attr="z"
    start="-5"
    end="-100"
    duration="5000"
    loop="true"
    ping-pong="true"
    easing="easeInOutQuart"
  ></m-attr-anim>
</m-cube>

<m-cube x="5" y="0.5" z="5" width="3" height="0.25" depth="3" color="blue">
  <m-attr-anim
    attr="z"
    start="-5"
    end="-20"
    duration="5000"
    loop="true"
    ping-pong="true"
    easing="easeInOutQuart"
  ></m-attr-anim>
</m-cube>

<m-cube x="-5" y="0.5" z="5" width="3" height="0.25" depth="3" color="blue">
  <m-attr-anim
    attr="z"
    start="-5"
    end="-20"
    duration="5000"
    loop="true"
    ping-pong="true"
    easing="easeInOutQuart"
  ></m-attr-anim>
  <m-attr-anim
    attr="ry"
    start="0"
    end="360"
    duration="5000"
    loop="true"
    ping-pong="true"
    easing="easeInOutQuart"
  ></m-attr-anim>
  <m-attr-anim
    attr="height"
    start="0.25"
    end="3.5"
    duration="5000"
    loop="true"
    ping-pong="true"
    easing="easeInOutQuart"
  ></m-attr-anim>
</m-cube>

<m-cube x="-10" z="-5" y="0.5" z="5" width="3" height="0.25" depth="3" color="blue">
  <m-attr-anim
    attr="ry"
    start="0"
    end="360"
    duration="5000"
    loop="true"
    ping-pong="true"
    easing="easeInOutQuart"
  ></m-attr-anim>
</m-cube>

<m-cube x="-10" y="0.5" z="5" width="3" height="0.25" depth="3" color="blue">
  <m-attr-anim
    attr="y"
    start="0.5"
    end="100"
    duration="5000"
    loop="true"
    ping-pong="true"
    easing="easeInOutQuart"
  ></m-attr-anim>
</m-cube>

<m-cube x="-15" y="2" z="-5" width="3" height="0.25" depth="12" rx="30" color="blue"></m-cube>
<m-cube x="-20" y="0.5" z="-5" width="3" height="0.25" depth="12" rx="10" color="blue"></m-cube>

<script>
  // Attach a click listener to the cube and spawn an m-sphere child of the cube wherever it is clicked
  const cube = document.getElementById("my-cube");
  console.log(cube);
  cube.addEventListener("click", (event) => {
    console.log("Clicked on cube", event, event.detail);
    const x = event.detail.position.x;
    const y = event.detail.position.y;
    const z = event.detail.position.z;
    const sphere = document.createElement("m-sphere");
    sphere.setAttribute("x", x);
    sphere.setAttribute("y", y);
    sphere.setAttribute("z", z);
    sphere.setAttribute("radius", 0.5);
    sphere.setAttribute("color", "red");
    cube.appendChild(sphere);
  });
</script>

<script>
  const stairs = document.getElementById("stairs");

  function getHexForCurrentTime(lightness) {
    const hue = ((Date.now() % 2000)/2000) * 360;
    const saturation = 1.0;
    const alpha = saturation * Math.min(lightness, 1 - lightness);
    const getF = number => {
      const k = (number + hue / 30) % 12;
      return lightness - alpha * Math.max(-1, Math.min(k - 3, Math.min(9 - k, 1)))
    };
    const red = Math.round(255 * getF(0));
    const green = Math.round(255 * getF(8));
    const blue = Math.round(255 * getF(4));
    const hex = "#"+(red.toString(16).padStart(2, "0"))+(green.toString(16).padStart(2, "0"))+(blue.toString(16).padStart(2, "0"));
    return hex;
  }

  for (let i = 0; i < 15; i++) {
    const stair = document.createElement("m-cube");
    stair.setAttribute("z", i * 0.5);
    stair.setAttribute("y", i * 0.2);
    stair.setAttribute("width", 2);
    stair.setAttribute("height", 0.2);
    stair.setAttribute("depth", 0.5);
    stair.setAttribute("color", "blue");
    stair.setAttribute("collision-interval","1000");
    stair.addEventListener("collisionstart", () => {
      stair.setAttribute("color", "white");
    });
    stair.addEventListener("collisionend", () => {
      stair.setAttribute("color", getHexForCurrentTime(0.5));
    });
    stairs.append(stair);
  }
</script>
