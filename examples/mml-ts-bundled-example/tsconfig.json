{
  "compilerOptions": {
    "noImplicitAny": true,
    "esModuleInterop": true,
    "module": "esnext",
    "target": "ES6",
    "lib": ["es2020", "dom"],
    "sourceMap": true,
    "strictNullChecks": true,
    "moduleResolution": "node",
    "outDir": "./build",
    "incremental": true
  },
  "include": ["src/**/*", "./build.ts"],
  "exclude": ["**/build/*"]
}
