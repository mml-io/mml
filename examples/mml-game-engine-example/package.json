{
  "name": "mml-game-engine-example",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "scripts": {
    "type-check": "tsc --noEmit -p ./tsconfig.json",
    "pre:build": "npm run build",
    "build": "tsx ./build.ts --build",
    "iterate": "tsx ./build.ts --watch",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --fix",
    "dev": "npm run iterate"
  },
  "dependencies": {
    "mml-game-engine-client": "^0.1.0",
    "ai-game-creator-systems-common": "file:../systems/systems-common",
    "ai-game-creator-project-bundler": "file:../project-bundler",
    "@mml-io/networked-dom-document": "0.21.1",
    "@mml-io/networked-dom-web-runner": "0.21.1"
  },
  "devDependencies": {
    "@craftamap/esbuild-plugin-html": "^0.7.0",
    "@types/express": "^4.17.21",
    "@types/node": "20.19.10",
    "@types/ws": "^8.5.10",
    "chokidar": "^3.5.3",
    "esbuild": "0.20.2",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-style-plugin": "^1.6.3",
    "express": "^4.19.2",
    "ws": "^8.16.0"
  }
}
