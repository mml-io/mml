{
  "name": "top-down-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "scripts": {
    "type-check": "tsc --noEmit -p ./tsconfig.json",
    "pre:build": "npm run build",
    "build": "node ../../packages/mml-cli/build/index.js build",
    "dev": "node ../../packages/mml-cli/build/index.js dev",
    "iterate": "node ../../packages/mml-cli/build/index.js dev",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --fix"
  },
  "dependencies": {
    "mml-game-engine-client": "*",
    "mml-game-systems-common": "*",
    "mml-game-project-bundler": "*",
    "@mml-io/networked-dom-document": "*",
    "@mml-io/networked-dom-web-runner": "*",
    "@mml-io/mml-game-engine-build-plugin": "*"
  },
  "devDependencies": {
    "@mml-io/mml-cli": "*",
    "@craftamap/esbuild-plugin-html": "^0.7.0",
    "@types/express": "5.0.6",
    "@types/node": "20.19.10",
    "@types/ws": "^8.5.10",
    "chokidar": "^3.5.3",
    "esbuild": "0.20.2",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-style-plugin": "^1.6.3",
    "express": "5.2.1",
    "ws": "^8.16.0"
  }
}
