{
  "name": "multi-game-builder",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "scripts": {
    "type-check": "tsc --noEmit -p ./tsconfig.json",
    "build": "tsx ./build.ts --build",
    "iterate": "tsx ./build.ts --watch",
    "start-server": "node --enable-source-maps ./build/index.js --serve",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --fix"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "esbuild": "0.20.2",
    "express": "5.1.0",
    "express-ws": "5.0.2",
    "yargs": "^17.7.2",
    "@mml-io/networked-dom-server": "file:../../packages/networked-dom-server",
    "@mml-io/mml-game-engine-build-plugin": "file:../../packages/mml-game-engine-build-plugin"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/express-ws": "3.0.5",
    "@types/node": "20.19.10",
    "@types/yargs": "^17.0.32",
    "concurrently": "^9.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
