{
  "name": "mml-editor-vscode-extension",
  "displayName": "MML Preview",
  "description": "Preview MML scenes from the active VS Code editor using the mml-editor preview client.",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:mml.preview"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mml.preview",
        "title": "MML: Open Preview"
      }
    ]
  },
  "scripts": {
    "build": "tsx ./build.ts",
    "watch": "tsx ./build.ts --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"src/**/*.{ts,tsx}\" --fix"
  },
  "dependencies": {
    "mml-game-engine-client": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "20.19.10",
    "@types/vscode": "^1.93.0",
    "esbuild": "0.20.2",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  }
}

