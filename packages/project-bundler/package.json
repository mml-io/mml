{
  "name": "mml-game-project-bundler",
  "displayName": "Project Bundler",
  "private": true,
  "version": "0.1.0",
  "description": "Helpers for bundling a project into a single file",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "/build"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "pre:build": "npm run build",
    "build": "tsx ./build.ts --build",
    "iterate": "tsx ./build.ts --watch",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --fix"
  },
  "dependencies": {
    "lodash": "4.17.21",
    "esbuild-wasm": "0.25.8",
    "mml-game-systems-common": "file:../systems/systems-common",
    "mml-game-physics-system": "file:../systems/physics",
    "mml-game-navigation-system": "file:../systems/navigation",
    "mml-game-math-system": "file:../systems/math"
  },
  "devDependencies": {
    "@types/node": "20.19.10",
    "esbuild": "^0.20.2",
    "esbuild-plugin-copy": "^2.1.1",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5"
  }
}
