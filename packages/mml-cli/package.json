{
  "name": "@mml-io/mml-cli",
  "version": "0.26.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mml-io/mml.git",
    "directory": "packages/mml-cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mml": "./build/index.js"
  },
  "type": "module",
  "files": [
    "/build"
  ],
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsx ./build.ts --build",
    "iterate": "tsx ./build.ts --watch",
    "lint": "eslint \"./**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./**/*.{js,jsx,ts,tsx}\" --fix",
    "test": "vitest run",
    "test-iterate": "vitest"
  },
  "dependencies": {
    "@mml-io/mml-schema-validator": "^0.26.0",
    "@mml-io/mml-web-client": "^0.26.0",
    "@mml-io/networked-dom-document": "^0.26.0",
    "@mml-io/networked-dom-server": "^0.26.0"
  },
  "//": "Third-party packages are in devDependencies because they are bundled by esbuild at build time (see build.ts). Only @mml-io/* workspace packages are kept as runtime dependencies (marked external in the bundle).",
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/express-ws": "3.0.6",
    "@types/picomatch": "^4.0.2",
    "chokidar": "5.0.0",
    "commander": "13.1.0",
    "express": "5.2.1",
    "express-ws": "5.0.2",
    "picomatch": "^4.0.3",
    "ws": "8.19.0"
  }
}
