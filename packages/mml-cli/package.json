{
  "name": "@mml-io/mml-cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "mml": "./build/index.js"
  },
  "files": [
    "/build",
    "/templates"
  ],
  "scripts": {
    "type-check": "tsc --noEmit -p ./tsconfig.json",
    "build": "tsx ./build.ts --build",
    "iterate": "tsx ./build.ts --watch",
    "lint": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./src/**/*.{js,jsx,ts,tsx}\" --fix"
  },
  "dependencies": {
    "@mml-io/mml-game-engine-build-plugin": "file:../mml-game-engine-build-plugin",
    "@mml-io/networked-dom-server": "file:../networked-dom-server",
    "chokidar": "^3.6.0",
    "express": "5.1.0",
    "mml-game-engine-client": "file:../mml-game-engine-client",
    "mml-game-project-bundler": "file:../project-bundler",
    "ws": "^8.18.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "20.19.10",
    "@types/ws": "^8.5.10",
    "@types/yargs": "^17.0.32",
    "esbuild": "0.20.2",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  }
}
