{
  "name": "@mml-io/mml-editor-core",
  "private": true,
  "version": "0.21.3",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
