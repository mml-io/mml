{
  "compilerOptions": {
    "noImplicitAny": true,
    "module": "esnext",
    "target": "ES2020",
    "jsx": "react-jsx",
    "lib": ["es2020", "dom"],
    "sourceMap": true,
    "types": ["node"],
    "strictNullChecks": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "downlevelIteration": true,
    "outDir": "./build",
    "incremental": true
  },
  "include": ["src/**/*", "./build.ts"],
  "exclude": ["**/build/*", "node_modules"]
}

