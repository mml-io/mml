{
  "name": "@mml-io/networked-dom-web-client",
  "version": "0.26.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/mml-io/mml.git",
    "directory": "packages/networked-dom-web-client"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "/build"
  ],
  "type": "module",
  "main": "build/index.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "tsx ./build.ts --build",
    "iterate": "cross-env PORT=28892 tsx ./build.ts --serve",
    "lint": "eslint \"./**/*.{js,jsx,ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"./**/*.{js,jsx,ts,tsx}\" --fix"
  },
  "dependencies": {
    "@mml-io/networked-dom-web": "^0.26.1"
  }
}
