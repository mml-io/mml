{
  "name": "mml-editor-vscode-extension",
  "displayName": "MML Editor",
  "description": "Live preview and visual editing for MML scenes with scene outline, element settings, and transform controls.",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:xml",
    "onView:mmlSceneOutline",
    "onView:mmlElementSettings",
    "onCustomEditor:mml.glbViewer"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mml.openPreview",
        "title": "MML: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "mml.openPreviewSideBySide",
        "title": "MML: Open Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "mml.showCodeOnly",
        "title": "MML: Show Code Only",
        "icon": "$(code)"
      },
      {
        "command": "mml.showPreviewOnly",
        "title": "MML: Show Preview Only",
        "icon": "$(preview)"
      },
      {
        "command": "mml.showSplitView",
        "title": "MML: Show Split View",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "mml.toggleVisualizers",
        "title": "MML: Toggle Element Visualizers",
        "icon": "$(eye)"
      },
      {
        "command": "mml.setGizmoTranslate",
        "title": "MML: Set Gizmo to Translate",
        "icon": "$(move)"
      },
      {
        "command": "mml.setGizmoRotate",
        "title": "MML: Set Gizmo to Rotate",
        "icon": "$(sync)"
      },
      {
        "command": "mml.setGizmoScale",
        "title": "MML: Set Gizmo to Scale",
        "icon": "$(screen-full)"
      },
      {
        "command": "mml.toggleSnapping",
        "title": "MML: Toggle Transform Snapping",
        "icon": "$(layout)"
      },
      {
        "command": "mml.focusSceneOutline",
        "title": "MML: Focus Scene Outline"
      },
      {
        "command": "mml.focusElementSettings",
        "title": "MML: Focus Element Settings"
      },
      {
        "command": "mml.glb.toggleBounds",
        "title": "GLB Viewer: Toggle Bounding Box",
        "icon": "$(symbol-ruler)"
      },
      {
        "command": "mml.glb.toggleWireframe",
        "title": "GLB Viewer: Toggle Wireframe",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "mml.glb.toggleCollider",
        "title": "GLB Viewer: Toggle Rapier Collider",
        "icon": "$(shield)"
      },
      {
        "command": "mml.glb.resetCamera",
        "title": "GLB Viewer: Reset Camera",
        "icon": "$(home)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mml.openPreviewSideBySide",
          "when": "(resourceExtname == .mml || resourceExtname == .html) && !mmlPreviewActive",
          "group": "navigation@1"
        },
        {
          "command": "mml.showCodeOnly",
          "when": "mmlPreviewActive",
          "group": "navigation@1"
        },
        {
          "command": "mml.showSplitView",
          "when": "mmlPreviewActive",
          "group": "navigation@2"
        },
        {
          "command": "mml.showPreviewOnly",
          "when": "mmlPreviewActive",
          "group": "navigation@3"
        },
        {
          "command": "mml.glb.toggleBounds",
          "when": "activeCustomEditorId == mml.glbViewer",
          "group": "navigation@1"
        },
        {
          "command": "mml.glb.toggleWireframe",
          "when": "activeCustomEditorId == mml.glbViewer",
          "group": "navigation@2"
        },
        {
          "command": "mml.glb.toggleCollider",
          "when": "activeCustomEditorId == mml.glbViewer",
          "group": "navigation@3"
        },
        {
          "command": "mml.glb.resetCamera",
          "when": "activeCustomEditorId == mml.glbViewer",
          "group": "navigation@4"
        }
      ],
      "editor/title/run": [
        {
          "command": "mml.toggleVisualizers",
          "when": "webviewFocus && activeWebviewPanelId == mmlPreview",
          "group": "mml@1"
        },
        {
          "command": "mml.toggleSnapping",
          "when": "webviewFocus && activeWebviewPanelId == mmlPreview",
          "group": "mml@2"
        }
      ],
      "commandPalette": [
        {
          "command": "mml.openPreview",
          "when": "resourceExtname == .mml || resourceExtname == .html || editorLangId == html"
        },
        {
          "command": "mml.openPreviewSideBySide",
          "when": "resourceExtname == .mml || resourceExtname == .html || editorLangId == html"
        },
        {
          "command": "mml.showCodeOnly",
          "when": "mmlPreviewActive"
        },
        {
          "command": "mml.showPreviewOnly",
          "when": "mmlPreviewActive"
        },
        {
          "command": "mml.showSplitView",
          "when": "mmlPreviewActive"
        },
        {
          "command": "mml.glb.toggleBounds",
          "when": "activeCustomEditorId == mml.glbViewer"
        },
        {
          "command": "mml.glb.toggleWireframe",
          "when": "activeCustomEditorId == mml.glbViewer"
        },
        {
          "command": "mml.glb.toggleCollider",
          "when": "activeCustomEditorId == mml.glbViewer"
        },
        {
          "command": "mml.glb.resetCamera",
          "when": "activeCustomEditorId == mml.glbViewer"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mml.openPreviewSideBySide",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .mml || resourceExtname == .html"
      },
      {
        "command": "mml.setGizmoTranslate",
        "key": "w",
        "when": "webviewFocus && activeWebviewPanelId == mmlPreview"
      },
      {
        "command": "mml.setGizmoRotate",
        "key": "e",
        "when": "webviewFocus && activeWebviewPanelId == mmlPreview"
      },
      {
        "command": "mml.setGizmoScale",
        "key": "r",
        "when": "webviewFocus && activeWebviewPanelId == mmlPreview"
      },
      {
        "command": "mml.toggleSnapping",
        "key": "x",
        "when": "webviewFocus && activeWebviewPanelId == mmlPreview"
      },
      {
        "command": "mml.toggleVisualizers",
        "key": "h",
        "when": "webviewFocus && activeWebviewPanelId == mmlPreview"
      }
    ],
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "mmlSceneOutline",
          "name": "MML Scene",
          "when": "mmlPreviewActive",
          "contextualTitle": "MML Scene Outline"
        },
        {
          "type": "webview",
          "id": "mmlElementSettings",
          "name": "MML Element",
          "when": "mmlPreviewActive",
          "contextualTitle": "MML Element Settings"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "mmlSceneOutline",
        "contents": "No MML preview active.\n[Open Preview](command:mml.openPreviewSideBySide)"
      },
      {
        "view": "mmlElementSettings",
        "contents": "No element selected.\nSelect an element in the scene to view its settings."
      }
    ],
    "languages": [
      {
        "id": "mml",
        "extensions": [".mml"],
        "aliases": ["MML", "mml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "mml.glbViewer",
        "displayName": "MML GLB Viewer",
        "selector": [
          {
            "filenamePattern": "*.glb"
          }
        ],
        "priority": "option"
      }
    ]
  },
  "scripts": {
    "build": "tsx ./build.ts",
    "iterate": "tsx ./build.ts --watch",
    "watch": "tsx ./build.ts --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint-fix": "eslint \"src/**/*.{ts,tsx}\" --fix"
  },
  "dependencies": {
    "@mml-io/mml-editor-core": "^0.21.3",
    "mml-game-engine-client": "^0.1.0",
    "mml-game-systems-common": "^0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "20.19.10",
    "@types/vscode": "^1.93.0",
    "esbuild": "0.20.2",
    "esbuild-style-plugin": "^1.6.3",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.20.3",
    "typescript": "^5.5.4"
  }
}
