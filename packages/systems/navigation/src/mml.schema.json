{
  "schema": {
    "name": "navigation",
    "displayName": "Navigation System",
    "description": "Provides navmesh generation and simple navigation APIs",
    "version": "0.1.0",
    "type": "object",
    "properties": {
      "debug": {
        "type": "boolean",
        "description": "Show NavMesh debug lines in the scene",
        "default": false
      },
      "debugDrawMode": {
        "type": "string",
        "description": "Nav debug draw mode",
        "default": "navmesh",
        "enum": [
          "navmesh",
          "heightfieldWalkable",
          "heightfieldSolid",
          "compactHeightfieldSolid",
          "compactHeightfieldRegions",
          "compactHeightfieldDistance",
          "navmeshBVTree",
          "staticGeometry",
          "obstacles"
        ]
      },
      "tileSize": {
        "type": "integer",
        "description": "Navmesh tile size",
        "default": 32,
        "minimum": 0,
        "maximum": 256
      },
      "cellSize": {
        "type": "number",
        "description": "Recast cell size",
        "default": 0.1,
        "minimum": 0.05,
        "maximum": 2
      },
      "cellHeight": {
        "type": "number",
        "description": "Recast cell height",
        "default": 0.05,
        "minimum": 0.05,
        "maximum": 2
      },
      "walkableRadius": {
        "type": "number",
        "description": "Walkable radius",
        "default": 0.5
      },
      "walkableClimb": {
        "type": "number",
        "description": "Walkable climb",
        "default": 2
      },
      "walkableHeight": {
        "type": "number",
        "description": "Walkable height",
        "default": 2
      },
      "walkableSlopeAngle": {
        "type": "number",
        "description": "Walkable slope angle",
        "default": 60
      }
    },
    "additionalProperties": false
  },
  "attributes": [
    {
      "name": "nav-obstacle",
      "validElements": ["m-cube", "m-plane", "m-cylinder"],
      "schema": {
        "type": "boolean",
        "description": "Mark this element as a dynamic nav obstacle",
        "default": true
      }
    },
    {
      "name": "nav-agent",
      "validElements": [
        "m-character",
        "m-cube",
        "m-sphere",
        "m-model",
        "m-cylinder",
        "m-capsule",
        "m-plane"
      ],
      "schema": {
        "type": "boolean",
        "description": "Enable navigation agent behavior for this element",
        "default": true
      }
    },
    {
      "name": "nav-speed",
      "validElements": [
        "m-character",
        "m-cube",
        "m-sphere",
        "m-model",
        "m-cylinder",
        "m-capsule",
        "m-plane"
      ],
      "schema": {
        "type": "number",
        "description": "Max agent speed (units/sec)",
        "default": 3.5,
        "minimum": 0
      }
    },
    {
      "name": "nav-acceleration",
      "validElements": [
        "m-character",
        "m-cube",
        "m-sphere",
        "m-model",
        "m-cylinder",
        "m-capsule",
        "m-plane"
      ],
      "schema": {
        "type": "number",
        "description": "Max agent acceleration (units/sec^2)",
        "default": 8.0,
        "minimum": 0
      }
    },
    {
      "name": "nav-goal-x",
      "validElements": [
        "m-character",
        "m-cube",
        "m-sphere",
        "m-model",
        "m-cylinder",
        "m-capsule",
        "m-plane"
      ],
      "schema": {
        "type": "number",
        "description": "Goal X coordinate for navigation (local/world depends on system usage)",
        "default": 0
      }
    },
    {
      "name": "nav-goal-y",
      "validElements": [
        "m-character",
        "m-cube",
        "m-sphere",
        "m-model",
        "m-cylinder",
        "m-capsule",
        "m-plane"
      ],
      "schema": {
        "type": "number",
        "description": "Goal Y coordinate for navigation",
        "default": 0
      }
    },
    {
      "name": "nav-goal-z",
      "validElements": [
        "m-character",
        "m-cube",
        "m-sphere",
        "m-model",
        "m-cylinder",
        "m-capsule",
        "m-plane"
      ],
      "schema": {
        "type": "number",
        "description": "Goal Z coordinate for navigation",
        "default": 0
      }
    },
    {
      "name": "nav-waypoints",
      "validElements": [
        "m-character",
        "m-cube",
        "m-sphere",
        "m-model",
        "m-cylinder",
        "m-capsule",
        "m-plane"
      ],
      "schema": {
        "type": "string",
        "description": "Semicolon-separated waypoints as x,y,z; e.g. '0,0,0; 1,0,1'",
        "default": ""
      }
    }
  ]
}

