{
  "schema": {
    "name": "navigation",
    "displayName": "Navigation System",
    "description": "Provides navmesh generation and simple navigation APIs",
    "version": "0.1.0",
    "type": "object",
    "properties": {
      "debug": {
        "type": "boolean",
        "description": "Show NavMesh debug lines in the scene",
        "default": false
      },
      "debugDrawMode": {
        "type": "string",
        "description": "Nav debug draw mode",
        "default": "navmesh",
        "enum": [
          "navmesh",
          "heightfieldWalkable",
          "heightfieldSolid",
          "compactHeightfieldSolid",
          "compactHeightfieldRegions",
          "compactHeightfieldDistance",
          "navmeshBVTree",
          "staticGeometry",
          "obstacles"
        ]
      },
      "tileSize": {
        "type": "integer",
        "description": "Navmesh tile size",
        "default": 32,
        "minimum": 0,
        "maximum": 256
      },
      "cellSize": {
        "type": "number",
        "description": "Recast cell size",
        "default": 0.1,
        "minimum": 0.05,
        "maximum": 2
      },
      "cellHeight": {
        "type": "number",
        "description": "Recast cell height",
        "default": 0.05,
        "minimum": 0.05,
        "maximum": 2
      },
      "walkableRadius": {
        "type": "number",
        "description": "Walkable radius",
        "default": 0.5
      },
      "walkableClimb": {
        "type": "number",
        "description": "Walkable climb",
        "default": 2
      },
      "walkableHeight": {
        "type": "number",
        "description": "Walkable height",
        "default": 2
      },
      "walkableSlopeAngle": {
        "type": "number",
        "description": "Walkable slope angle",
        "default": 60
      }
    },
    "additionalProperties": false
  },
  "attributes": [
    "nav-obstacle",
    "nav-agent",
    "nav-speed",
    "nav-acceleration",
    "nav-goal-x",
    "nav-goal-y",
    "nav-goal-z",
    "nav-waypoints"
  ]
}

