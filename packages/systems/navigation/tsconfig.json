{
    "compilerOptions": {
        "rootDir": "src",
        "tsBuildInfoFile": "tsconfig.tsbuildinfo",
        "incremental": true,
        "skipLibCheck": true,
        "downlevelIteration": true,
        "esModuleInterop": true,
        "jsx": "react",
        "lib": [
            "esnext",
            "dom"
        ],
        "module": "esnext",
        "moduleResolution": "bundler",
        "preserveConstEnums": true,
        "resolveJsonModule": true,
        "noImplicitAny": true,
        "sourceMap": true,
        "strict": true,
        "strictNullChecks": true,
        "target": "es2020",
        "types": [
            "node"
        ]
    },
    "include": [
        "./src/**/*"
    ],
    "exclude": [
        "**/build/*"
    ]
}

