{
  "name": "mml",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "scripts": {
    "preinstall": "node ./check-node-version.js",
    "serve": "turbo run serve --output-logs=full --concurrency=5 --continue",
    "serve-debug": "turbo run serve-debug --output-logs=full --concurrency=5 --continue",
    "build": "turbo run build --output-logs=full",
    "start": "npm run iterate",
    "iterate": "npm run build && npm run iterate-without-build",
    "iterate-without-build": "turbo run iterate --output-logs=full --concurrency=1000 --continue",
    "test-all": "turbo run test --output-logs=full --concurrency=5 --continue",
    "lint-all": "turbo run lint --output-logs=full --concurrency=5 --continue --filter=!top-down-game",
    "lint-fix-all": "turbo run lint-fix --output-logs=full --concurrency=5 --continue --filter=!top-down-game",
    "type-check-all": "turbo run type-check --output-logs=full --concurrency=5 --continue --filter=!top-down-game",
    "check": "npm run build && npm run type-check-all && npm run lint-all",
    "link-all": "lerna exec \"npm link\" --no-private && npm run print-links",
    "print-links": "echo \"Run this command in the package you would like to link this repo's packages to:\n\"; echo \"npm link\" $(lerna ls --loglevel=error)",
    "version": "lerna version --no-push --force-publish"
  },
  "workspaces": [
    "packages/**/*",
    "!packages/mml-cli/templates/**",
    "examples/**/*"
  ],
  "devDependencies": {
    "@babel/preset-typescript": "7.27.1",
    "@eslint/js": "9.31.0",
    "@swc/core": "1.12.14",
    "@swc/jest": "0.2.39",
    "@types/express-ws": "^3.0.5",
    "@types/jest": "29.5.13",
    "@types/jju": "1.4.5",
    "@types/node": "25.0.9",
    "@types/resolve": "1.20.6",
    "@types/tmp": "0.2.6",
    "@vitest/ui": "^4.0.18",
    "concurrently": "9.2.0",
    "cross-env": "7.0.3",
    "esbuild": "0.20.2",
    "esbuild-jest": "0.5.0",
    "esbuild-plugin-copy": "2.1.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "express-ws": "^5.0.2",
    "jest": "29.7.0",
    "jju": "1.4.0",
    "lerna": "9.0.0",
    "mdn-data": "^2.12.2",
    "prettier": "3.6.2",
    "publish-if-not-exists": "1.1.0",
    "resolve": "1.22.11",
    "tmp": "0.2.5",
    "ts-node": "10.9.2",
    "tsx": "4.20.3",
    "turbo": "2.7.5",
    "typescript": "5.5.4",
    "typescript-eslint": "8.36.0",
    "vitest": "^4.0.18"
  }
}
